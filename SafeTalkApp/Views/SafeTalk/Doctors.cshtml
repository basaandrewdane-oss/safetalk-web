@{
    Layout = "~/Views/Shared/_SafeTalkLayout.cshtml";
}
<style>
    /* Accent hover effect */
    .card .card-action a:not(.btn):hover {
        color: #B39DDB !important; /* deep-purple lighten-3 */
    }
</style>

<main style="margin: 0px 50px">
    <div class="row">
        <div class="col s12">
            <!-- Neutral heading -->
            <h4 class="grey-text text-darken-4 center">Our Doctors</h4>
        </div>
    </div>

    <div class="row">
        <div class="col s12 m6">
            <!-- Secondary color card -->
            <div class="card teal lighten-2 white-text z-depth-2">
                <div class="card-content">
                    <!-- Primary title color -->
                    <span class="card-title pink-text text-lighten-5">Doctor 1</span>
                    <p class="white-text">
                        I am a very simple card. I am good at containing small bits of information.
                    </p>
                </div>
                <!-- Neutral background for action -->
                <div class="card-action grey lighten-5">
                    <!-- Accent link -->
                    <a href="#" class="deep-purple-text text-lighten-2">
                        Book Consultation
                    </a>
                </div>
            </div>
        </div>

        <div class="col s12 m6">
            <!-- Example using Primary color card -->
            <div class="card pink lighten-2 white-text z-depth-2">
                <div class="card-content">
                    <span class="card-title">Doctor 2</span>
                    <p class="white-text">
                        I am another simple card, styled with the primary brand color.
                    </p>
                </div>
                <div class="card-action grey lighten-5">
                    <a href="#" class="deep-purple-text text-lighten-2">
                        Book Consultation
                    </a>
                </div>
            </div>
        </div>
    </div>
</main>
