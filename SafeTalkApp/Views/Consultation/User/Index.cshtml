@{
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<!-- User Consultation Page -->
<main>
    <div class="container" ng-init="getPatientConsultations()" ng-controller="ConsultationController" ng-cloak>
        <h4 class="pink-text text-lighten-2">Consultations</h4>
        <div class="divider"></div>
        <div ng-if="verifiedAppointments.length > 0">
            <table class="display responsive nowrap" id="verifiedAppointmentsTable">
                <thead>
                    <tr>
                        <th>Action</th>
                        <th>Doctor</th>
                        <th>Date</th>
                        <th>Start Time</th>
                        <th>End Time</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                    <tr ng-repeat="consult in verifiedAppointments">
                        <td>
                            <div class="center" ng-switch="consult.status">
                                <button ng-switch-when="3" class="btn green" ng-click="goToConsultation(consult.appointmentID)">Join</button>
                                <button ng-switch-when="6" class="waves-effect waves-light btn teal lighten-2" ng-click="downloadTranscript(consult.appointmentID)">Download Transcript</button>
                                <button ng-if="consult.hasReferral"
                                        class="waves-effect waves-light btn pink lighten-2"
                                        ng-click="viewReferral(consult.referralID)">
                                    View Referral
                                </button>
                            </div>
                        </td>
                        <td>{{consult.doctorName}}</td>
                        <td>{{consult.date | dotNetDate | date: 'yyyy-MM-dd'}}</td>
                        <td>{{consult.startTime | timespanToTime}}</td>
                        <td>{{consult.endTime | timespanToTime}}</td>
                        <td ng-switch="consult.status">
                            <span ng-switch-when="3" class="green-text">Available</span>
                            <span ng-switch-when="6" class="green-text">Completed</span>
                        </td>
                    </tr>
                </tbody>
            </table>
            <!-- Referral Modal -->
            <div id="viewReferralModal" class="modal">
                <div class="modal-content">
                    <h5 class="pink-text text-lighten-2">Referral Details</h5>
                    <div class="divider"></div>
                    <p><b>Referred To:</b> {{ selectedReferral.sentTo }}</p>
                    <p><b>Reason:</b> {{ selectedReferral.reason }}</p>
                    <p><b>Urgency:</b> {{ selectedReferral.urgencyLevel }}</p>
                    <p><b>Date Issued:</b> {{ selectedReferral.dateCreated | date:'mediumDate'  }}</p>
                </div>
                <div class="modal-footer">
                    <a class="modal-close waves-effect waves-light btn pink lighten-2">Close</a>
                </div>
            </div>

        </div>
        <div class="center-align" ng-if="verifiedAppointments.length === 0">
            <p class="grey-text">No consultations available at this time.</p>
        </div>
    </div>
</main>
