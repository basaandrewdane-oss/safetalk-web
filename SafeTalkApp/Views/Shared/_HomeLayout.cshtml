<!DOCTYPE html>

<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>@ViewBag.Title</title>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/materialize/1.0.0/css/materialize.min.css">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/materialize/1.0.0/js/materialize.min.js"></script>
    <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet">
    <style>
        main {
            min-height: 100vh;
        }

        .btn {
            border-radius: 20px;
        }

        .btn-large {
            border-radius: 30px;
        }
        /*label color */
        .input-field label {
            color: #616161;
        }
        /*underline color */
        .input-field input[type=email], textarea.materialize-textarea {
            border-bottom: 1px solid #616161 !important;
        }
            /*label focus color */
            .input-field input[type=email]:focus + label, textarea.materialize-textarea:focus + label {
                color: #4db6ac !important;
            }
            /*label underline focus color */
            .input-field input[type=email]:focus, textarea.materialize-textarea:focus {
                border-bottom: 1px solid #4db6ac !important;
                box-shadow: 0 1px 0 0 #4db6ac !important;
            }

        .col ul li a:hover {
            color: #B39DDB !important; /* example: deep-purple lighten-3 */
            text-decoration: underline; /* optional */
            transition: color 0.3s ease; /* smooth transition */
        }

        ul#mobile-demo li a:hover {
            color: #B39DDB !important; /* example: deep-purple lighten-3 */
            text-decoration: underline; /* optional */
            transition: color 0.3s ease; /* smooth transition */
        }

        .chat-message {
            display: inline-block;
            padding: 10px 14px;
            margin: 6px 0;
            border-radius: 16px;
            max-width: 75%;
            word-wrap: break-word;
            white-space: pre-line; /* respects \n as line breaks */
            line-height: 1.4;
            font-size: 14px;
            clear: both;
            box-sizing: border-box;
        }

            /* Reset any inner element padding/margin */
            .chat-message p,
            .chat-message span,
            .chat-message div {
                margin: 0 !important;
                padding: 0 !important;
                text-indent: 0 !important;
            }

        /* USER message (right-aligned, grey bubble) */
        .user-msg {
            background-color: #eeeeee;
            color: #000;
            float: right;
            text-align: left;
            border-bottom-right-radius: 4px;
        }

        /* BOT message (left-aligned, purple bubble) */
        .bot-msg {
            background-color: #7e57c2;
            color: white;
            float: left;
            text-align: left;
            border-bottom-left-radius: 4px;
        }

        .chatbot-window {
            position: fixed;
            bottom: 80px;
            right: 20px;
            width: 300px;
            height: 400px; /* fixed height for the chat window */
            display: flex;
            flex-direction: column;
            z-index: 9999;
        }

        /* Messages area scrolls */
        .messages-container {
            flex: 1;
            overflow-y: auto;
            padding-bottom: 10px;
        }

        /* Input fixed at bottom */
        .chat-input {
            border-top: 1px solid #ddd;
        }

        .typing-indicator {
            display: inline-flex;
            align-items: center;
            gap: 4px;
            padding: 10px 14px;
            background-color: #7e57c2;
            border-radius: 16px;
            /*max-width: 75%;*/
        }

            .typing-indicator span {
                width: 6px;
                height: 6px;
                background: white;
                border-radius: 50%;
                display: inline-block;
                animation: blink 1.4s infinite both;
            }

                .typing-indicator span:nth-child(2) {
                    animation-delay: 0.2s;
                }

                .typing-indicator span:nth-child(3) {
                    animation-delay: 0.4s;
                }

        @@keyframes blink {
            0% {
                opacity: .2;
            }

            20% {
                opacity: 1;
            }

            100% {
                opacity: .2;
            }
        }

        .suggested-prompts {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
            margin: 8px 0;
        }

            .suggested-prompts button {
                background: #f0f0f0;
                border: none;
                border-radius: 16px;
                padding: 6px 12px;
                cursor: pointer;
                font-size: 14px;
                transition: background 0.2s;
            }

                .suggested-prompts button:hover {
                    background: #ddd;
                }

        [ng-cloak] {
            display: none !important;
        }

        .swal2-select {
            width: 85%;
        }
    </style>
</head>
<body ng-app="SafeTalkApp" ng-controller="AccountController">
    <div class="navbar-fixed">
        <nav class="pink lighten-2">
            <div class="nav-wrapper container">
                <a href="@Url.Action("Index", "Home")" class="brand-logo">SafeTalk</a>
                <a href="#" data-target="mobile-demo" class="sidenav-trigger"><i class="material-icons ">menu</i></a>
                <ul class="right hide-on-med-and-down">
                    <li><a href="@Url.Action("Index", "Home")" class="">Home</a></li>
                    <li><a href="@Url.Action("Doctors", "Home")" class="">Doctors</a></li>
                    <li><a href="@Url.Action("Contact", "Home")" class="">Contact</a></li>
                    <li><a href="@Url.Action("About", "Home")" class="">About Us</a></li>
                    <li><a href="@Url.Action("Login", "Account")" class="waves-effect waves-light btn teal lighten-2" style="margin: 5px;">Log In</a></li>
                    <li><a href="#" class="waves-effect waves-light btn deep-purple lighten-2" ng-click="getRoles()" style="margin: 5px;">Sign Up</a></li>
                </ul>
            </div>
        </nav>
    </div>

    <ul class="sidenav" id="mobile-demo">
        <li class="active"><a href="@Url.Action("Index", "Home")" class="">Home</a></li>
        <li><a href="@Url.Action("Doctors", "Home")" class="">Our Doctors</a></li>
        <li><a href="@Url.Action("Contact", "Home")" class="">Contact</a></li>
        <li><a href="@Url.Action("About", "Home")" class="">About Us</a></li>
        <li><a href="@Url.Action("Login", "Account")">Log In</a></li>
        <li><a href="#" ng-click="getRoles()">Sign Up</a></li>
    </ul>
    <div>
        @RenderBody()
    </div>

    <footer class="page-footer grey lighten-5 grey-text text-darken-4">
        <div class="container">
            <div class="row">
                <div class="col l6 s12">
                    <h5 class="">Give Us A Feedback</h5>
                    <p class="">Send us an email.</p>
                    <div class="row">
                        <form class="col s12">
                            <div class="row">
                                <div class="input-field col s12">
                                    <input id="email" type="email" class="validate">
                                    <label for="email">Email</label>
                                    <span class="helper-text" data-error="Invalid email" data-success="Looks good!">Enter email address.</span>
                                </div>
                                <div class="input-field col s12">
                                    <textarea id="textarea1" class="materialize-textarea"></textarea>
                                    <label for="textarea1">Share your feedback</label>
                                </div>
                            </div>
                        </form>
                    </div>
                </div>
                <div class="col l4 offset-l2 s12">
                    <h5 class="">Links</h5>
                    <ul>
                        <li><a class="grey-text text-darken-2" href="@Url.Action("Index", "Home")">Home</a></li>
                        <li><a class="grey-text text-darken-2" href="@Url.Action("Doctors", "Home")">Our Doctors</a></li>
                        <li><a class="grey-text text-darken-2" href="@Url.Action("Contact", "Home")">Contact</a></li>
                        <li><a class="grey-text text-darken-2" href="@Url.Action("About", "Home")">About</a></li>
                    </ul>
                </div>
            </div>
        </div>
        <div ng-controller="ChatBotController">
            <!-- Floating Chat Button -->
            <div class="fixed-action-btn">
                <a class="btn-floating btn-large purple" ng-click="toggleChat()">
                    <i class="material-icons">chat</i>
                </a>
            </div>

            <!-- Chat Window -->
            <div id="chatbot-window" class="card chatbot-window" ng-show="chatOpen" ng-cloak>
                <div class="card-content messages-container">
                    <span class="card-title">AI Chatbot</span>

                    <!-- Messages -->
                    <div ng-repeat="m in messages"
                         class="chat-message"
                         ng-class="{'user-msg': m.from=='user', 'bot-msg': m.from=='bot'}">{{m.text}}</div>

                    <!-- ✅ Suggested prompts -->
                    <div class="suggested-prompts" ng-if="promptsVisible">
                        <button ng-repeat="prompt in prompts"
                                ng-click="usePrompt(prompt, $event)">
                            {{prompt.text}}
                        </button>
                    </div>

                    <!-- Typing indicator -->
                    <div class="chat-message bot-msg typing-indicator" ng-if="typing">
                        <span></span><span></span><span></span>
                    </div>
                </div>

                <!-- Input always visible -->
                <div class="card-action chat-input">
                    <form ng-submit="sendMessage()">
                        <div class="input-field">
                            <input type="text" ng-model="message" placeholder="Type a message..." />
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <div class="footer-copyright deep-purple lighten-3">
            <div class="container white-text">
                © 2025 SafeTalk
            </div>
        </div>
    </footer>
    <script src="~/Scripts/jquery-3.7.0.min.js"></script>
    <script src="~/Scripts/angular.min.js"></script>
    @Scripts.Render("~/bundles/safetalkapp")
    <script>
        // sidenav initialization
        document.addEventListener('DOMContentLoaded', function () {
            var elems = document.querySelectorAll('.sidenav');
            var instances = M.Sidenav.init(elems);
        });
        // slider initialization
        document.addEventListener('DOMContentLoaded', function () {
            var elems = document.querySelectorAll('.slider');
            var instances = M.Slider.init(elems);
        });
        // parallax initialization
        document.addEventListener('DOMContentLoaded', function () {
            var elems = document.querySelectorAll('.parallax');
            var instances = M.Parallax.init(elems);
        });
    </script>
</body>
</html>
