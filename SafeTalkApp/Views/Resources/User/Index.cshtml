@{
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}
<!-- User Resources View -->
<main ng-controller="ResourcesController">
    <div class="container">
        <h4 class="pink-text text-lighten-2">Resources</h4>
        <div class="divider"></div>
    </div>
    <br />
    <div class="container">
        <div class="row">
            <div class="col s12 m6 l4" ng-repeat="res in resources">
                <div class="card hover-card">
                    <div class="card-image waves-effect waves-block waves-light">
                        <img class="activator" src="~/Content/Images/firstSlide.jpeg">
                    </div>
                    <div class="card-content">
                        <span class="card-title activator">{{res.title}}</span>
                        <p>{{res.category}} • {{res.type}}</p>
                        <p class="grey-text">{{res.publishedDate | date: 'yyyy-MM-dd'}}</p>
                    </div>
                    <div class="card-action">
                        <a ng-href="{{res.url}}" target="_blank">Learn More</a>
                    </div>
                    <!-- Hover Content -->
                    <div class="hover-content">
                        <p>{{res.content}}</p>
                        <a class="hover-link" ng-href="{{res.url}}" target="_blank">Read More</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</main>