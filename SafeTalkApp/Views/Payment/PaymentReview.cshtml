@{
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    @model SafeTalkApp.DTOs.Payment.PaymentReviewDTO
}

<style>
    .review-container {
        margin-top: 40px;
    }

    .review-card {
        border-radius: 20px;
        padding: 25px;
    }

    .review-title {
        font-weight: 600;
        margin-bottom: 20px;
    }

    .review-detail {
        font-size: 1.1rem;
        margin: 12px 0;
    }

        .review-detail strong {
            color: #512da8; /* deep purple */
        }

    .action-buttons {
        margin-top: 25px;
    }

    .btn-custom {
        border-radius: 30px;
        font-size: 1rem;
    }
</style>

<div class="container review-container">
    <h4 class="purple-text text-darken-2 center-align">Review Your Payment</h4>
    <div class="divider"></div>

    <div class="row center-align">
        <div class="col s12 m8 offset-m2">
            <div class="card z-depth-3 review-card">
                <div class="card-content">
                    <p class="review-detail"><strong>👨‍⚕️ Doctor:</strong> @Model.DoctorName</p>
                    <p class="review-detail"><strong>📅 Appointment Date:</strong> @Model.Date.ToShortDateString() @Model.Time</p>
                    <p class="review-detail"><strong>💰 Consultation Fee:</strong> PHP @Model.Fee</p>
                </div>

                <div class="card-action action-buttons center-align">
                    <form action="@Url.Action("CapturePayPalOrder", "Payment")" method="post">
                        <input type="hidden" name="token" value="@Model.Token" />
                        <input type="hidden" name="appointmentID" value="@Model.AppointmentID" />

                        <button type="submit" class="btn green darken-1 waves-effect waves-light btn-custom" style="margin-right: 15px;">Confirm & Pay
                        </button>

                        <a href="@Url.Action("Appointments", "Appointment")" class="btn red lighten-1 waves-effect waves-light btn-custom">Cancel
                        </a>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
