@{
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    @model SafeTalkApp.DTOs.Payment.PaymentProcessingDTO
}
<main>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            // Show loading first
            Swal.fire({
                title: 'Processing Payment',
                text: 'Please wait while we confirm your transaction...',
                allowOutsideClick: false,
                allowEscapeKey: false,
                didOpen: () => {
                    Swal.showLoading();
                }
            });

            // After a short delay, show result
            setTimeout(function () {
                @if (Model.Success != null && (bool)Model.Success)
                {
                    <text>
                        Swal.fire({
                            icon: 'success',
                            title: 'Payment Confirmed!',
                            html: 'Transaction ID: <b>@Model.TransactionId</b><br/>Amount: @Model.Amount @Model.Currency',
                            confirmButtonText: 'Go to Appointments'
                        }).then(() => {
                            window.location.href = '/Appointment/Appointments';
                        });
                    </text>
                }
                else
                {
                    <text>
                        Swal.fire({
                            icon: 'error',
                            title: 'Payment Failed',
                            text: '@Model.ErrorMessage',
                            confirmButtonText: 'Back to Appointments'
                        }).then(() => {
                            window.location.href = '/Appointment/Appointments';
                        });
                    </text>
                }
            }, 1500); // small delay for loader effect
        });
    </script>
</main>
