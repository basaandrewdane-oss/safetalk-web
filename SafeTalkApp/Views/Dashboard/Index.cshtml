@{
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<style>
    .btn-small {
        border-radius: 30px;
    }

    .card {
        border-radius: 30px;
        transition: transform 0.3s, box-shadow 0.3s;
    }

        .card.hoverable:hover {
            transform: translateY(-5px);
            box-shadow: 0 8px 20px rgba(0, 0, 0, 0.15);
        }

    .card-action.center.deep-purple.lighten-5 {
        border-bottom-left-radius: 30px;
        border-bottom-right-radius: 30px;
    }

    .stat-card {
        border-radius: 20px;
    }
</style>

<!-- Dashboard Index -->
<main class="grey lighten-5" style="min-height:100vh;">
    <div class="container">
        <div class="section">
            <!-- Greeting -->
            <h5 class="center-align pink-text text-lighten-2">
                Welcome, @User.Identity.Name!
            </h5>
            <p class="center-align grey-text text-darken-2">
                Here’s a quick overview of your activities and tools.
            </p>

            <!-- Chart Section -->
            <div class="row">
                <!-- User and Doctor Charts-->
                @if (User.IsInRole("User") || User.IsInRole("Doctor"))
                {
                    <div class="col s12 m8 offset-m2 l4">
                        <div class="card-panel white center">
                            <canvas id="appointmentChart" height="150"></canvas>
                        </div>
                    </div>
                    <div class="col s12 m8 offset-m2 l8">
                        <div class="card-panel white center">
                            <canvas id="consultationTrendChart" height="150"></canvas>
                        </div>
                    </div>
                }

            </div>

            <!-- Quick Stats Row -->
            @if (User.IsInRole("User") || User.IsInRole("Doctor"))
            {
                <div ng-controller="DashboardController" ng-init="loadStats()">
                    <div class="row">
                        <div class="col s12 m4 l3">
                            <div class="card-panel teal lighten-4 center stat-card">
                                <h6>Upcoming Appointments</h6>
                                <p class="flow-text">{{stats.UpcomingAppointments}}</p> <!-- Replace with dynamic count -->
                            </div>
                        </div>
                        <div class="col s12 m4 l3">
                            <div class="card-panel deep-purple lighten-4 center stat-card">
                                <h6>Active Consultations</h6>
                                <p class="flow-text">{{stats.ActiveConsultations}}</p> <!-- Replace with dynamic count -->
                            </div>
                        </div>
                        <div class="col s12 m4 l3">
                            <div class="card-panel light-blue lighten-4 center stat-card">
                                <h6>Completed Consultations</h6>
                                <p class="flow-text">{{stats.CompletedConsultations}}</p>
                            </div>
                        </div>
                        <div class="col s12 m4 l3">
                            <div class="card-panel grey lighten-4 center stat-card">
                                <h6>Resources</h6>
                                <p class="flow-text">{{stats.Resources}}</p>
                            </div>
                        </div>
                    </div>
                </div>
            }

            <!-- Admin Reports -->
            @if (User.IsInRole("Admin"))
            {
                <div ng-controller="DashboardController" ng-init="loadAdminReports()">
                    <div class="row">
                        <!-- Appointment Status Chart -->
                        <div class="col s12 m6 l6">
                            <div class="card-panel white z-depth-1 center">
                                <h6>Appointment Status Overview</h6>
                                <canvas id="adminStatusChart" height="150"></canvas>
                            </div>
                        </div>

                        <!-- Appointment Trend Chart -->
                        <div class="col s12 m6 l6">
                            <div class="card-panel white z-depth-1 center">
                                <h6>Appointments Over Time</h6>
                                <canvas id="adminTrendChart" height="300"></canvas>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <!-- User Growth Chart -->
                        <div class="col s12 m6 l6">
                            <div class="card-panel white z-depth-1 center">
                                <h6>User Growth (Patients vs Doctors)</h6>
                                <canvas id="userGrowthChart" height="150"></canvas>
                            </div>
                        </div>

                        <!-- Resources Uploaded Chart -->
                        <div class="col s12 m6 l6">
                            <div class="card-panel white z-depth-1 center">
                                <h6>Resources Uploaded per Month</h6>
                                <canvas id="resourceChart" height="150"></canvas>
                            </div>
                        </div>
                    </div>
                </div>
            }

            <!-- Dashboard Tools -->
            <div class="row">

                <!-- User Tools -->
                @if (User.IsInRole("User"))
                {
                    <h6 class="grey-text text-darken-2">User Tools</h6>

                    <div class="col s12 m6 l6">
                        <div class="card hoverable">
                            <div class="card-content center">
                                <i class="material-icons medium teal-text text-lighten-2">event_available</i>
                                <h6 class="grey-text text-darken-4">Book Consultation</h6>
                                <p class="grey-text text-darken-2">Schedule a consultation with a doctor.</p>
                            </div>
                            <div class="card-action center deep-purple lighten-5">
                                <a href="@Url.Action("Book", "Appointment")" class="btn-small deep-purple lighten-3">View</a>
                            </div>
                        </div>
                    </div>

                    <div class="col s12 m6 l6">
                        <div class="card hoverable">
                            <div class="card-content center">
                                <i class="material-icons medium teal-text text-lighten-2">groups</i>
                                <h6 class="grey-text text-darken-4">Doctors</h6>
                                <p class="grey-text text-darken-2">View available professionals.</p>
                            </div>
                            <div class="card-action center deep-purple lighten-5">
                                <a href="@Url.Action("DoctorsView", "Home")" class="btn-small deep-purple lighten-3">View</a>
                            </div>
                        </div>
                    </div>
                }

                <!-- User & Doctor Tools -->
                @if (User.IsInRole("User") || User.IsInRole("Doctor"))
                {
                    <h6 class="grey-text text-darken-2">Appointments & Consultations</h6>

                    <div class="col s12 m6 l6">
                        <div class="card hoverable">
                            <div class="card-content center">
                                <i class="material-icons medium teal-text text-lighten-2">event</i>
                                <h6 class="grey-text text-darken-4">Appointments</h6>
                                <p class="grey-text text-darken-2">Manage and view your upcoming appointments.</p>
                            </div>
                            <div class="card-action center deep-purple lighten-5">
                                <a href="@Url.Action("Appointments", "Appointment")" class="btn-small deep-purple lighten-3">View</a>
                            </div>
                        </div>
                    </div>

                    <div class="col s12 m6 l6">
                        <div class="card hoverable">
                            <div class="card-content center">
                                <i class="material-icons medium teal-text text-lighten-2">chat</i>
                                <h6 class="grey-text text-darken-4">Consultations</h6>
                                <p class="grey-text text-darken-2">Read and send messages securely.</p>
                            </div>
                            <div class="card-action center deep-purple lighten-5">
                                <a href="@Url.Action("Consultations", "Consultation")" class="btn-small deep-purple lighten-3">View</a>
                            </div>
                        </div>
                    </div>
                }

                <!-- Doctor Tools -->
                @if (User.IsInRole("Doctor"))
                {
                    <div class="col s12 m6 l6">
                        <h6 class="grey-text text-darken-2">Doctor Tools</h6>
                        <div class="card hoverable">
                            <div class="card-content center">
                                <i class="material-icons medium teal-text text-lighten-2">access_time</i>
                                <h6 class="grey-text text-darken-4">Availability</h6>
                                <p class="grey-text text-darken-2">Set your consultation schedule.</p>
                            </div>
                            <div class="card-action center deep-purple lighten-5">
                                <a href="@Url.Action("Index", "Availability")" class="btn-small deep-purple lighten-3">View</a>
                            </div>
                        </div>
                    </div>
                }

                <!-- Admin Tools -->
                @if (User.IsInRole("Admin"))
                {
                    <h6 class="grey-text text-darken-2">Admin Tools</h6>

                    <div class="col s12 m6 l6">
                        <div class="card hoverable">
                            <div class="card-content center">
                                <i class="material-icons medium teal-text text-lighten-2">manage_accounts</i>
                                <h6 class="grey-text text-darken-4">Manage Users</h6>
                                <p class="grey-text text-darken-2">View and manage all platform users.</p>
                            </div>
                            <div class="card-action center deep-purple lighten-5">
                                <a href="@Url.Action("ManageUsers", "Admin")" class="btn-small deep-purple lighten-3">View</a>
                            </div>
                        </div>
                    </div>

                    <div class="col s12 m6 l6">
                        <div class="card hoverable">
                            <div class="card-content center">
                                <i class="material-icons medium teal-text text-lighten-2">view_list</i>
                                <h6 class="grey-text text-darken-4">Pending Doctors</h6>
                                <p class="grey-text text-darken-2">Review and approve pending doctor accounts.</p>
                            </div>
                            <div class="card-action center deep-purple lighten-5">
                                <a href="@Url.Action("PendingDoctors", "Admin")" class="btn-small deep-purple lighten-3">View</a>
                            </div>
                        </div>
                    </div>

                    <div class="col s12 m6 l6">
                        <div class="card hoverable">
                            <div class="card-content center">
                                <i class="material-icons medium teal-text text-lighten-2">question_mark</i>
                                <h6 class="grey-text text-darken-4">Manage FAQs</h6>
                                <p class="grey-text text-darken-2">Review and update FAQs</p>
                            </div>
                            <div class="card-action center deep-purple lighten-5">
                                <a href="@Url.Action("FAQs", "Admin")" class="btn-small deep-purple lighten-3">View</a>
                            </div>
                        </div>
                    </div>

                    <div class="col s12 m6 l6">
                        <div class="card hoverable">
                            <div class="card-content center">
                                <i class="material-icons medium teal-text text-lighten-2">payments</i>
                                <h6 class="grey-text text-darken-4">Manage Payments</h6>
                                <p class="grey-text text-darken-2">Review and update payments</p>
                            </div>
                            <div class="card-action center deep-purple lighten-5">
                                <a href="@Url.Action("Payments", "Admin")" class="btn-small deep-purple lighten-3">View</a>
                            </div>
                        </div>
                    </div>

                    <div class="col s12 m6 l6">
                        <div class="card hoverable">
                            <div class="card-content center">
                                <i class="material-icons medium teal-text text-lighten-2">description</i>
                                <h6 class="grey-text text-darken-4">Manage Terms</h6>
                                <p class="grey-text text-darken-2">Review and update terms</p>
                            </div>
                            <div class="card-action center deep-purple lighten-5">
                                <a href="@Url.Action("ManageTerms", "Admin")" class="btn-small deep-purple lighten-3">View</a>
                            </div>
                        </div>
                    </div>
                }

                <!-- Common Tools -->
                <div class="col s12 m6 l6">
                    <h6 class="grey-text text-darken-2">General Tools</h6>
                    <div class="card hoverable">
                        <div class="card-content center">
                            <i class="material-icons medium teal-text text-lighten-2">library_books</i>
                            <h6 class="grey-text text-darken-4">Resources</h6>
                            <p class="grey-text text-darken-2">Access mental health and wellness resources.</p>
                        </div>
                        <div class="card-action center deep-purple lighten-5">
                            <a href="@Url.Action("Index", "Resources")" class="btn-small deep-purple lighten-3">View</a>
                        </div>
                    </div>
                </div>

                <!-- Reports -->
                @if (User.IsInRole("Doctor"))
                {
                    <div class="col s12 m12 l12">
                        <h6 class="grey-text text-darken-2">Reports</h6>
                        <div class="row">
                            <div class="col s12 m6 l4">
                                <div class="card hoverable">
                                    <div class="card-content center">
                                        <i class="material-icons medium teal-text text-lighten-2">trending_up</i>
                                        <h6 class="grey-text text-darken-4">Consultation Trends</h6>
                                        <p class="grey-text text-darken-2">View number of consultations over time.</p>
                                    </div>
                                    <div class="card-action center deep-purple lighten-5">
                                        <a href="@Url.Action("ConsultationReport", "Reports")" class="btn-small deep-purple lighten-3">View</a>
                                    </div>
                                </div>
                            </div>

                            <div class="col s12 m6 l4">
                                <div class="card hoverable">
                                    <div class="card-content center">
                                        <i class="material-icons medium teal-text text-lighten-2">history</i>
                                        <h6 class="grey-text text-darken-4">Patient History</h6>
                                        <p class="grey-text text-darken-2">View a complete history of each patient you’ve seen.</p>
                                    </div>
                                    <div class="card-action center deep-purple lighten-5">
                                        <a href="@Url.Action("PatientHistory", "Reports")" class="btn-small deep-purple lighten-3">View</a>
                                    </div>
                                </div>
                            </div>

                            <div class="col s12 m6 l4">
                                <div class="card hoverable">
                                    <div class="card-content center">
                                        <i class="material-icons medium teal-text text-lighten-2">assignment</i>
                                        <h6 class="grey-text text-darken-4">Follow-ups & Missed</h6>
                                        <p class="grey-text text-darken-2">Track missed appointments and follow-ups.</p>
                                    </div>
                                    <div class="card-action center deep-purple lighten-5">
                                        <a href="@Url.Action("FollowUpReport", "Reports")" class="btn-small deep-purple lighten-3">View</a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                }

                @if (User.IsInRole("User"))
                {
                    <div class="col s12 m6 l6">
                        <h6 class="grey-text text-darken-2">Reports</h6>
                        @*<div class="col s12 m6 l4">
                        <div class="card hoverable">
                            <div class="card-content center">
                                <i class="material-icons medium teal-text text-lighten-2">trending_up</i>
                                <h6 class="grey-text text-darken-4">Consultation Trends</h6>
                                <p class="grey-text text-darken-2">View number of consultations over time.</p>
                            </div>
                            <div class="card-action center deep-purple lighten-5">
                                <a href="@Url.Action("ConsultationReport", "Reports")" class="btn-small deep-purple lighten-3">View</a>
                            </div>
                        </div>
                    </div>*@


                        <div class="card hoverable">
                            <div class="card-content center">
                                <i class="material-icons medium teal-text text-lighten-2">history</i>
                                <h6 class="grey-text text-darken-4">Doctor History</h6>
                                <p class="grey-text text-darken-2">View a complete history of each doctor you’ve seen.</p>
                            </div>
                            <div class="card-action center deep-purple lighten-5">
                                <a href="@Url.Action("DoctorHistory", "Reports")" class="btn-small deep-purple lighten-3">View</a>
                            </div>
                        </div>

                        <div class="card hoverable">
                            <div class="card-content center">
                                <i class="material-icons medium teal-text text-lighten-2">assignment</i>
                                <h6 class="grey-text text-darken-4">Follow-ups & Missed</h6>
                                <p class="grey-text text-darken-2">Track missed appointments and follow-ups.</p>
                            </div>
                            <div class="card-action center deep-purple lighten-5">
                                <a href="@Url.Action("FollowUpReport", "Reports")" class="btn-small deep-purple lighten-3">View</a>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</main>
