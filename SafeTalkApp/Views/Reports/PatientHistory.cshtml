@{
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}


<div ng-controller="ReportsController" ng-init="getPatientHistory()" class="row">

    <!-- Patients -->
    <div ng-if="!selectedPatient">
        <h4 class="center-align">Patients</h4>

        <div class="col s12 m6 l4" ng-repeat="patient in patientHistory">
            <div class="card hoverable z-depth-2">
                <div class="card-content">
                    <span class="card-title">{{patient.FullName}}</span>
                    <p><b>Email:</b> {{patient.Email}}</p>
                    <p><b>Phone:</b> {{patient.Phone}}</p>
                </div>
                <div class="card-action right-align">
                    <button class="btn-small teal lighten-1 waves-effect"
                            ng-click="loadHistory(patient.PatientID)">
                        View History
                    </button>
                </div>
            </div>
        </div>
    </div>
    <!-- Patient History -->
    <div ng-if="selectedPatient" class="col s12">
        <h4 class="center-align">History for {{selectedPatient.FullName}}</h4>

        <div class="col s12 m6 l4" ng-repeat="h in patientHistory">
            <div class="card hoverable z-depth-2">
                <div class="card-content">
                    <span class="card-title">{{h.Date | dotNetDate | date:'mediumDate'}}</span>
                    <p><b>Time:</b> {{h.Time}}</p>
                    <div ng-switch="h.Status">
                        <p><b>Status: </b><span ng-switch-when="6" class="green-text">Completed</span></p>
                    </div>
                </div>
            </div>
        </div>

        <div class="col s12 center-align" style="margin-top:20px;">
            <button class="btn grey waves-effect" ng-click="backToPatients()">
                Back to Patients
            </button>
        </div>
    </div>

</div>
