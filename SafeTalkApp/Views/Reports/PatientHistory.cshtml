@{
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}


<div class="container row" ng-controller="ReportsController" ng-init="getPatientHistory()">

    <!-- Patients -->
    <div ng-if="!selectedPatient" class="col s12">
        <h4 class="center-align">Patients</h4>
        <table id="patientsTable" class="display responsive nowrap">
            <thead>
                <tr>
                    <th>Full Name</th>
                    <th>Email</th>
                    <th>Phone</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                <tr ng-repeat="patient in patientHistory">
                    <td>{{patient.FullName}}</td>
                    <td>{{patient.Email}}</td>
                    <td>{{patient.Phone}}</td>
                    <td>
                        <button class="btn-small teal lighten-1 waves-effect"
                                ng-click="loadHistory(patient.PatientID)">
                            View History
                        </button>
                    </td>
                </tr>
            </tbody>
        </table>
    </div>

    <!-- Patient History -->
    <div ng-if="selectedPatient" class="col s12">
        <h4 class="center-align">History for {{selectedPatient.FullName}}</h4>
        <table id="historyTable" class="highlight responsive-table">
            <thead>
                <tr>
                    <th>Date</th>
                    <th>Time</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody>
                <tr ng-repeat="h in patientHistory">
                    <td>{{h.Date | dotNetDate | date:'mediumDate'}}</td>
                    <td>{{h.Time}}</td>
                    <td>
                        <span ng-switch="h.Status">
                            <span ng-switch-when="0" class="orange-text">Pending Approval</span>
                            <span ng-switch-when="1" class="blue-text">Approved - Awaiting Payment</span>
                            <span ng-switch-when="2" class="orange-text">Payment Submitted</span>
                            <span ng-switch-when="3" class="green-text">Paid</span>
                            <span ng-switch-when="4" class="red-text">Rejected</span>
                            <span ng-switch-when="5" class="grey-text">Canceled</span>
                            <span ng-switch-when="6" class="green-text">Completed</span>
                            <span ng-switch-when="7" class="red-text">Missed</span>
                            <span ng-switch-default class="grey-text">Unknown</span>
                        </span>
                    </td>
                </tr>
            </tbody>
        </table>

        <div class="center-align" style="margin-top:20px;">
            <button class="btn grey waves-effect" ng-click="backToPatients()">
                Back to Patients
            </button>
        </div>
    </div>

</div>
