@{
    Layout = "~/Views/Shared/_HomeLayout.cshtml";
}

<main>
    <div class="container">
        <div class="row">
            <div class="col s12 center">
                <!-- Primary pink for main heading -->
                <h3 class="pink-text text-lighten-2">About SafeTalk</h3>
                <p class="grey-text text-darken-2">
                    SafeTalk is a trusted consultation platform dedicated to sexual health and education.
                    We provide confidential, reliable, and accessible resources to help individuals make informed decisions
                    about their reproductive health and overall well-being.
                </p>
            </div>
        </div>

        <!-- Mission & Vision Section -->
        <div class="row">
            <div class="col s12 m6 center">
                <i class="material-icons teal-text text-lighten-2 large">favorite</i>
                <h5 class="deep-purple-text text-lighten-2">Our Mission</h5>
                <p class="grey-text text-darken-2">
                    To empower individuals through education, open conversation, and professional guidance
                    in a safe and supportive environment.
                </p>
            </div>
            <div class="col s12 m6 center">
                <i class="material-icons teal-text text-lighten-2 large">lightbulb</i>
                <h5 class="deep-purple-text text-lighten-2">Our Vision</h5>
                <p class="grey-text text-darken-2">
                    A community where everyone feels confident, informed, and safe in making decisions
                    about their sexual and reproductive health.
                </p>
            </div>
        </div>

        <!-- Core Values -->
        <div class="row center" style="margin-top:40px;">
            <!-- Accent deep-purple for section title -->
            <h4 class="deep-purple-text text-lighten-2">Our Values</h4>
            <div class="col s12 m4">
                <i class="material-icons teal-text text-lighten-2 large">verified_user</i>
                <h6 class="grey-text text-darken-4">Confidentiality</h6>
                <p class="grey-text text-darken-2">Your privacy and trust are our top priority.</p>
            </div>
            <div class="col s12 m4">
                <i class="material-icons teal-text text-lighten-2 large">school</i>
                <h6 class="grey-text text-darken-4">Education</h6>
                <p class="grey-text text-darken-2">We provide accurate, science-based resources and guidance.</p>
            </div>
            <div class="col s12 m4">
                <i class="material-icons teal-text text-lighten-2 large">people</i>
                <h6 class="grey-text text-darken-4">Compassion</h6>
                <p class="grey-text text-darken-2">We listen, understand, and support without judgment.</p>
            </div>
        </div>

        <!-- Call to Action -->
        <div class="row center" style="margin-top:50px;">
            <!-- Primary button -->
            <a class="waves-effect waves-light btn-large pink lighten-2" href="/Consultations">
                Book a Consultation
            </a>
        </div>
    </div>
</main>
