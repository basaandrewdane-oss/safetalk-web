@{
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}


<div ng-controller="AdminController" ng-init="getTerms()" class="container" style="margin-top:30px;">
    <h4>Manage Terms and Conditions</h4>
    <p>Last updated terms can be edited below:</p>

    <textarea id="termsEditor" ng-model="termsContent" style="width:100%;height:300px;"></textarea>

    <br />
    <button class="btn waves-effect waves-light teal" ng-click="updateTerms()">
        Save Changes
    </button>

    <hr />

    <!-- Optional: Live Preview -->
    <h5>Preview:</h5>
    <div style="border:1px solid #ccc; padding:15px; border-radius:8px;" ng-bind-html="trustedHtml()"></div>
</div>

